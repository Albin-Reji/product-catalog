<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">

    <changeSet id="001-create-producers" author="albin">

        <!--
            PRECONDITION: If the 'producers' table already exists (e.g. created by
            Hibernate ddl-auto in a previous run), mark this changeset as already run
            and skip it — instead of crashing with "relation already exists".
        -->
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="producers"/>
            </not>
        </preConditions>

        <createTable tableName="producers">

            <!-- UUID primary key — matches GenerationType.UUID in Producer.java -->
            <column name="producer_id" type="varchar(36)">
                <constraints primaryKey="true"
                             primaryKeyName="pk_producers"
                             nullable="false"/>
            </column>

            <!-- producer_name: unique=true, nullable=false from @Column -->
            <column name="producer_name" type="varchar(255)">
                <constraints nullable="false" unique="true"
                             uniqueConstraintName="uq_producers_name"/>
            </column>

            <!-- address, email, phone: no constraints in model = nullable -->
            <column name="address" type="varchar(255)"/>

            <column name="email" type="varchar(255)"/>

            <column name="phone" type="varchar(50)"/>

        </createTable>

    </changeSet>

</databaseChangeLog>